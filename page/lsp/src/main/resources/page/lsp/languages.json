      "lspWindowsBinaries": ["kotlin-language-server.bat"],
      "installGuideUrl": "https://github.com/fwcd/kotlin-language-server",
      "install": {
        "macos": "brew install kotlin-language-server",
        "linux": "Download release zip from https://github.com/fwcd/kotlin-language-server/releases and add `bin/` to PATH",
        "windows": "Download release zip from https://github.com/fwcd/kotlin-language-server/releases and add `bin\\` to PATH"
      },
      "runCommand": null
    },
